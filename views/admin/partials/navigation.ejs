        <span></span>
    </div>
    <ul class="nav-menu" id="navMenu">
        <li class="nav-item">
            <a href="/admin/dashboard" class="nav-link <%= (typeof currentPage !== 'undefined' && currentPage === 'dashboard') ? 'active' : '' %>">
                <span class="nav-icon">📊</span>
                Dashboard
            </a>
        </li>
        
        <% if (typeof userPermissions !== 'undefined' && userPermissions.includes('menu_management')) { %>
        <li class="nav-item">
            <a href="/admin/menu" class="nav-link <%= (typeof currentPage !== 'undefined' && currentPage === 'menu') ? 'active' : '' %>">
                <span class="nav-icon">🍽️</span>
                Menu Management
            </a>
        </li>
        <% } %>
        
        <% if (typeof userPermissions !== 'undefined' && userPermissions.includes('waste_management')) { %>
        <li class="nav-item">
            <a href="/admin/waste" class="nav-link <%= (typeof currentPage !== 'undefined' && currentPage === 'waste') ? 'active' : '' %>">
                <span class="nav-icon">🗑️</span>
                Waste Data
            </a>
        </li>
        <% } %>
        
        <% if (typeof userPermissions !== 'undefined' && userPermissions.includes('special_menu_management')) { %>
        <li class="nav-item">
            <a href="/admin/special-menu" class="nav-link <%= (typeof currentPage !== 'undefined' && currentPage === 'special-menu') ? 'active' : '' %>">
                <span class="nav-icon">⭐</span>
                Special Menus
            </a>
        </li>
        <% } %>
        
        <% if (typeof userPermissions !== 'undefined' && userPermissions.includes('nutrition_management')) { %>
        <li class="nav-item">
            <a href="/admin/nutrition" class="nav-link <%= (typeof currentPage !== 'undefined' && currentPage === 'nutrition') ? 'active' : '' %>">
                <span class="nav-icon">🥗</span>
                Nutrition Data
            </a>
        </li>
        <% } %>
        
        <li class="nav-item">
            <a href="/admin/quotes" class="nav-link <%= (typeof currentPage !== 'undefined' && currentPage === 'quotes') ? 'active' : '' %>">
                <span class="nav-icon">💬</span>
                Quotes
            </a>
        </li>
        
        <% if (typeof userPermissions !== 'undefined' && userPermissions.includes('manage_users')) { %>
        <li class="nav-item">
            <a href="/admin/users" class="nav-link <%= (typeof currentPage !== 'undefined' && currentPage === 'users') ? 'active' : '' %>">
                <span class="nav-icon">👥</span>
